{
  "name": "bie-cms",
  "version": "1.0.0",
  "private": true,
  "description": "Pronounced \"Bye-CMS\", or \"Blogging is Easy\" - a light CMS built on semantic, tile-based blog components. Makes writing as simple as reading.",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:front dev:back",
    "dev:front": "npm --workspace=@apps/bie-frontend run dev",
    "dev:back": "npm --workspace=@apps/back_end      run dev",
    "build": "npm-run-all build:front build:back",
    "build:front": "npm --workspace=@apps/bie-frontend run build",
    "build:back": "npm --workspace=@apps/back_end      run build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brian-wastle/BIE-CMS.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/brian-wastle/BIE-CMS/issues"
  },
  "homepage": "https://github.com/brian-wastle/BIE-CMS#readme"
}
